# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Spotify API (Optional - not used anymore, Lavalink handles Spotify)
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Lavalink Configuration
# You can use multiple nodes for redundancy

# Main node
LAVALINK_MAIN_NAME=
LAVALINK_MAIN_URL=
LAVALINK_MAIN_AUTH=
LAVALINK_MAIN_SECURE=true

# Fallback node (optional)
LAVALINK_FALLBACK_NAME=
LAVALINK_FALLBACK_URL=
LAVALINK_FALLBACK_AUTH=
LAVALINK_FALLBACK_SECURE=

